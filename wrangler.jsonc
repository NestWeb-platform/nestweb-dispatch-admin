{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "nestweb-dispatch-admin",
	"main": "./src/index.ts",
	"compatibility_date": "2025-10-08",
	"upload_source_maps": true,
	"dispatch_namespaces": [
		{
			"binding": "DISPATCHER",
			"namespace": "nestweb-production",
			"remote": true
		}
	],
	"routes": [
		{
			"pattern": "sites.nestweb.ai/*",
			"zone_name": "nestweb.ai"
		},
		{
			"pattern": "*.sites.nestweb.ai/*",
			"zone_name": "nestweb.ai"
		}
	],
	"observability": {
		"enabled": true
	},
	"vars": {
		"CLOUDFLARE_ACCOUNT_ID": "a2f51a4158d294b40745b3dc57606833",
		"READONLY": "false"
	}
}
